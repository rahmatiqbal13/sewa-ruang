# ============================================================
# SUPABASE
# Dapatkan dari: https://supabase.com/dashboard/project/_/settings/api
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# UPSTASH REDIS
# Dapatkan dari: https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============================================================
# NOTIFIKASI EMAIL (Brevo / Resend)
# ============================================================
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Sistem Sewa Ruang

# Brevo SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-user
SMTP_PASS=your-brevo-smtp-password

# Atau Resend (pilih salah satu)
# RESEND_API_KEY=re_your-resend-api-key

# ============================================================
# NOTIFIKASI WHATSAPP (Meta Cloud API)
# Dapatkan dari: https://developers.facebook.com/apps
# ============================================================
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-webhook-verify-token

# ============================================================
# NOTIFIKASI TELEGRAM (Bot API)
# Buat bot via @BotFather di Telegram
# ============================================================
TELEGRAM_BOT_TOKEN=your-bot-token

# ============================================================
# PAYMENT GATEWAY (TBD: Midtrans / Xendit / Duitku)
# ============================================================
PAYMENT_GATEWAY=midtrans
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Sistem Sewa Ruang & Alat
