# ============================================================
# APP URL - Production (Vercel)
# ============================================================
NEXT_PUBLIC_APP_URL=https://sewa-ruang.vercel.app
NEXT_PUBLIC_APP_NAME=Sistem Sewa Ruang & Alat

# ============================================================
# UPSTASH REDIS - Optional (untuk rate limiting)
# Dapatkan dari: https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============================================================
# EMAIL SMTP - Brevo (WAJIB untuk forgot password)
# Dapatkan dari: https://app.brevo.com/settings/keys/smtp
# ============================================================
EMAIL_FROM=noreply@sewa-ruang.vercel.app
EMAIL_FROM_NAME="Sistem Sewa Ruang & Alat"
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-user
SMTP_PASS=your-brevo-smtp-password

# ============================================================
# NOTIFIKASI TELEGRAM - Optional
# Buat bot via @BotFather di Telegram
# ============================================================
TELEGRAM_BOT_TOKEN=your-bot-token

# ============================================================
# PAYMENT GATEWAY - Midtrans (jika pakai payment)
# ============================================================
PAYMENT_GATEWAY=midtrans
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false
